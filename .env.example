# .env.example — copy to .env and fill in values
# PENTING lokal: DEBUG=True, JANGAN set DJANGO_SETTINGS_MODULE=production di .env
SECRET_KEY=generate-with-python-secrets-token-hex
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (local — SQLite via config/settings/local.py)
# Production uses DATABASE_URL from Neon (see docs/DEPLOY.md)

# Social links (Contact Me section)
SOCIAL_GITHUB_URL=https://github.com/voouwx
SOCIAL_GITHUB_HANDLE=voouwx
SOCIAL_LINKEDIN_URL=https://linkedin.com/in/voouwx
SOCIAL_LINKEDIN_HANDLE=voouwx
SOCIAL_INSTAGRAM_URL=https://instagram.com/voouwx
SOCIAL_INSTAGRAM_HANDLE=voouwx
SOCIAL_X_URL=https://x.com/voouwx
SOCIAL_X_HANDLE=voouwx

# ── Render + Neon (production) — set di Render dashboard → Environment
# DJANGO_SETTINGS_MODULE=config.settings.production
# DEBUG=false
# SECRET_KEY=<python -c "import secrets; print(secrets.token_hex(32))">
# DATABASE_URL=<connection string dari Neon dashboard>
# ALLOWED_HOSTS=.onrender.com,namadomain.site
# SITE_DOMAIN=namadomain.site
# RENDER_EXTERNAL_HOSTNAME=<auto dari Render, opsional>
